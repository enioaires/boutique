---
const categories = [
  { label: "Apartamentos", slug: "apartamento" },
  { label: "Casas", slug: "casa" },
  { label: "Coberturas", slug: "cobertura" },
  { label: "Salas Comerciais", slug: "sala-comercial" },
  { label: "Lotes e Terrenos", slug: "lote" },
  { label: "Lançamentos", slug: "lancamento" },
];

// Duplica para o loop infinito ser seamless
const slides = [...categories, ...categories];
---

<section class="bg-white py-10 md:py-16 overflow-hidden">
  <div class="mx-auto max-w-7xl px-5 md:px-6">
    <h2 class="text-xl font-semibold text-verde-900 text-center md:text-2xl animate-fade-in-up">
      Busque imóveis através das nossas oportunidades
    </h2>
  </div>

  <!-- Fade nas bordas -->
  <div class="relative mt-8 md:mt-10">
    <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-12 bg-gradient-to-r from-white to-transparent md:w-24"></div>
    <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-12 bg-gradient-to-l from-white to-transparent md:w-24"></div>

    <!-- Track -->
    <div class="group">
      <div class="flex w-max animate-marquee group-hover:[animation-play-state:paused]">
        {slides.map((category) => (
          <a
            href={`/imoveis?tipo=${category.slug}`}
            class="w-52 shrink-0 px-3 sm:w-60 md:w-72 md:px-4"
          >
            <div class="aspect-[4/3] rounded-lg bg-verde-100 overflow-hidden flex items-center justify-center transition-transform duration-300 hover:scale-[1.03]">
              <span class="text-verde-300 text-sm">{category.label}</span>
            </div>
            <p class="mt-3 text-center text-sm font-medium text-verde-800 transition-colors duration-200 hover:text-verde-500">
              {category.label}
            </p>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
